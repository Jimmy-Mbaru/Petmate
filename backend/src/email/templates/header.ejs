<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PetMate</title>
    <style>
        body {
            font-family: 'Lato', 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: #f5eded;
            margin: 0;
            padding: 0;
            -webkit-font-smoothing: antialiased;
        }
        .wrapper {
            background-color: #f5eded;
            padding: 20px;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(215, 35, 35, 0.05);
        }
        .header {
            background-color: #d72323;
            padding: 50px 20px;
            text-align: center;
            background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.15) 1px, transparent 0);
            background-size: 20px 20px;
        }
        .header h1 {
            color: #ffffff;
            margin: 0;
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }
        .content {
            padding: 40px 40px;
            color: #363636;
            line-height: 1.8;
        }
        .content h2 {
            color: #000000;
            font-size: 24px;
            margin-top: 0;
            font-weight: 700;
        }
        .footer {
            background-color: #ffffff;
            padding: 30px;
            text-align: center;
            color: #888888;
            font-size: 13px;
            border-top: 1px solid #f0f0f0;
        }
        .btn {
            display: inline-block;
            padding: 16px 36px;
            background-color: #d72323;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 12px;
            font-weight: bold;
            font-size: 16px;
            margin: 25px 0;
            transition: background-color 0.3s ease;
        }
        .brand-text {
            color: #d72323;
            font-weight: bold;
        }
        .receipt-card {
            background-color: #fcfcfc;
            border: 1px solid #f0f0f0;
            border-radius: 16px;
            padding: 25px;
            margin: 25px 0;
        }
        .receipt-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            border-bottom: 1px dashed #eeeeee;
            padding-bottom: 10px;
        }
        .receipt-total {
            margin-top: 15px;
            font-size: 20px;
            font-weight: bold;
            color: #d72323;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <h1>PetMate</h1>
            </div>
            <div class="content">

<%- include('header') %>
<h2>Booking Status Update</h2>
<p>Hi <%= name %>,</p>
<p>There has been an update to your pet boarding booking <span class="brand-text">#<%= bookingId %></span>.</p>

<div style="background-color: #f9f9f9; padding: 20px; border-radius: 8px; margin: 20px 0; text-align: center;">
    <p style="margin: 0; font-size: 14px; color: #888888; text-transform: uppercase;">New Status</p>
    <p style="margin: 5px 0 0 0; font-size: 24px; font-weight: bold; color: #d72323;"><%= status %></p>
</div>

<div style="margin: 20px 0; padding: 0 10px;">
    <p><strong>Host:</strong> <%= hostName %></p>
    <p><strong>Dates:</strong> <%= startDate %> to <%= endDate %></p>
</div>

<div style="text-align: center;">
    <a href="<%= bookingLink %>" class="btn">View Booking Details</a>
</div>
<p>If you have any questions, feel free to reach out to the host directly via chat.</p>
<p>Best regards,<br>The PetMate Team</p>
<%- include('footer') %>
